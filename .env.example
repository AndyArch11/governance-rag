# RAG Ingestion Pipeline Configuration
# 
# This file documents all environment variables that can be used to configure
# the ingestion pipeline. Copy this to `.env` and customise as needed.
# The pipeline will automatically load variables from a `.env` file if present.
# Load order (lowest to highest priority):
#   1) Code defaults
#   2) .env (if present; does NOT override real env vars)
#   3) OS environment variables
#
# Secrets: do NOT store secrets in this file; inject them via your environment or a secrets manager.

# =============================================================================
# DEPLOYMENT ENVIRONMENT
# =============================================================================

# Deployment environment: Dev, Test, or Prod
# Controls log purging behaviour and other environment-specific settings
# - Dev: Full features enabled, --purge-logs allowed
# - Test: Similar to Dev with test-specific configurations
# - Prod: --purge-logs disabled for safety
# Default: Dev
ENVIRONMENT=Dev

# =============================================================================
# PATH CONFIGURATION
# =============================================================================

# Base path containing source HTML documents for ingestion
# Recommended structure: place each source in its own subdirectory
# E.g., ~/rag-project/data_raw/downloads/confluence/, ~/rag-project/data_raw/downloads/sharepoint/
# Categorise documents into subdirectories by source type for better organisation (used to inform LLM processing)
# E.g., governance, policies, procedures, manuals, etc.
# Documents are processed recursively from this base path
# Default: ~/rag-project/data_raw/downloads/
RAG_BASE_PATH=~/rag-project/data_raw/downloads/

# ChromaDB persistent storage location
# Default: ~/rag-project/rag_data
RAG_DATA_PATH=~/rag-project/rag_data

# =============================================================================
# CHROMADB COLLECTION NAMES
# =============================================================================

# Name of the collection storing document chunks
# Default: governance_docs_chunks
CHUNK_COLLECTION_NAME=governance_docs_chunks

# Name of the collection storing document-level metadata
# Default: governance_docs_documents
DOC_COLLECTION_NAME=governance_docs_documents

# =============================================================================
# URL SEED INGESTION (OPTIONAL - preview feature)
# =============================================================================

# Path to JSON file containing URL seeds for web scraping
# Default: ~/rag-project/data_raw/url_seeds.json
URL_SEED_JSON_PATH=~/rag-project/data_raw/url_seeds.json

# Directory for storing downloaded HTML from URLs
# Default: {RAG_BASE_PATH}/url_imports
URL_DOWNLOAD_DIR=~/rag-project/data_raw/downloads/url_imports

# =============================================================================
# LLM CACHING
# =============================================================================

# Unified SQLite cache backend (true/false)
# Controls whether cache operations are enabled globally
# Default: true
RAG_CACHE_ENABLED=true

# Path to unified cache database
# Used for LLM cache, embedding cache, graph cache, BM25 tables, and analytics
# Default: {RAG_DATA_PATH}/cache.db
RAG_CACHE_PATH=~/rag-project/rag_data/cache.db

# Enable/disable LLM output caching (true/false)
# Caches metadata generation, validation, and repair outputs
# Uses unified SQLite backend at {RAG_CACHE_PATH}
# Default: true
LLM_CACHE_ENABLED=true

# Legacy compatibility key for older JSON cache implementations
# Active implementation stores LLM cache entries in {RAG_CACHE_PATH} table: llm_cache
# Default: {RAG_DATA_PATH}/cache.db (via RAG_CACHE_PATH)
LLM_CACHE_PATH=~/rag-project/rag_data/cache.db

# Maximum age of cache entries in days (0 = never expire)
# Default: 0
LLM_CACHE_MAX_AGE_DAYS=0

# =============================================================================
# SEMANTIC DRIFT DETECTION
# =============================================================================

# Enable semantic drift detection for document updates (true/false)
# Compares summaries/topics between versions using LLM analysis
# Default: true
ENABLE_SEMANTIC_DRIFT_DETECTION=true

# =============================================================================
# CHUNK VALIDATION OPTIMISATION
# =============================================================================

# Enable chunk quality heuristic to skip validation for high-confidence chunks
# Uses length, stopword ratio, and entropy to detect clean chunks
# Default: true
ENABLE_CHUNK_HEURISTIC_SKIP=true

# =============================================================================
# PARENT-CHILD CHUNKING
# =============================================================================

# Enable parent-child chunking for improved context retrieval (true/false)
# Creates large parent chunks (1200 chars) for context alongside
# small child chunks (400 chars) for search. Children are embedded
# and searched; parents provide rich context when children match.
# Default: true
ENABLE_PARENT_CHILD_CHUNKING=true

# =============================================================================
# CANDIDATE TERM RECORDING (UNFAMILIAR DOMAINS)
# =============================================================================

# Record candidate terms from ingestion (true/false)
# Captures key_topics for human curation into candidate_terms.json
# Default: false
ENABLE_CANDIDATE_TERMS=false

# Optional domain label for candidate terms (e.g., legal, healthcare)
# Must match a DomainType value or it will be ignored
# Default: (empty)
CANDIDATE_TERMS_DOMAIN=

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================

# Number of concurrent worker threads
# Recommendations:
#   - CPU-only: 2-4 workers (I/O bound)
#   - GPU (8GB VRAM): 4-6 workers (balanced)
#   - GPU (16GB+ VRAM): 6-10 workers (LLM throughput limited)
# Monitor Ollama GPU utilisation and adjust accordingly
# Default: 4
MAX_WORKERS=4

# LLM rate limiting (requests per second)
# Prevents overwhelming Ollama with concurrent calls
# Adjust based on GPU capabilities and model size
# Default: 10.0
LLM_RATE_LIMIT=10.0

# Embedding batch size for efficient generation
# Larger batches = better throughput but more memory
# Default: 32
EMBEDDING_BATCH_SIZE=32

# =============================================================================
# EMBEDDING CACHING
# =============================================================================

# Enable/disable embedding caching (true/false)
# Reuses embeddings for identical chunk text across documents
# Uses unified SQLite backend at {RAG_CACHE_PATH}
# Default: true
EMBEDDING_CACHE_ENABLED=true

# Legacy compatibility key for older JSON cache implementations
# Active implementation stores embedding cache entries in {RAG_CACHE_PATH} table: embedding_cache
# Default: {RAG_DATA_PATH}/cache.db (via RAG_CACHE_PATH)
EMBEDDING_CACHE_PATH=~/rag-project/rag_data/cache.db

# =============================================================================
# BM25 KEYWORD INDEXING (HYBRID SEARCH)
# =============================================================================

# Enable/disable BM25 indexing during ingestion (true/false)
# Builds inverted index for keyword-based retrieval in hybrid search
# Index stores term frequencies, IDF values, and document lengths
# Indexed at ingestion time from original full document text, not summarised chunks
# Default: true
BM25_INDEXING_ENABLED=true

# Index original full text for BM25 (true/false)
# If true, stores complete original text for accurate keyword matching
# If false, only indexes chunk text (may lose keywords during summarisation)
# Recommended: true for best hybrid search results
# Default: true
BM25_INDEX_ORIGINAL_TEXT=true

# =============================================================================
# VERSION MANAGEMENT
# =============================================================================

# Number of document versions to retain in ChromaDB
# Older versions are automatically pruned
# Default: 3
VERSIONS_TO_KEEP=3

# =============================================================================
# PROGRESS LOGGING
# =============================================================================

# Log progress every N documents (0 = disable)
# Useful for monitoring long-running batch jobs in headless environments
# Default: 10
PROGRESS_LOG_INTERVAL=10

# =============================================================================
# EMERGENCY CONTROLS (USE WITH CAUTION)
# =============================================================================

# Delete entire ChromaDB storage on startup (true/false)
# WARNING: This is a last resort. Prefer using --reset CLI flag instead.
# Default: false
REINITIALISE_CHROMA_STORAGE=false

# =============================================================================
# USAGE NOTES
# =============================================================================
#
# 1. Copy this file to `.env` in your project root
# 2. Uncomment and modify only the values you want to change
# 3. The pipeline will automatically load .env variables on startup
# 4. CLI arguments override environment variables
# 5. Use absolute paths or ~ for home directory
#
# Example minimal .env:
#   RAG_BASE_PATH=~/my-docs/confluence
#   MAX_WORKERS=8
#   PROGRESS_LOG_INTERVAL=25
#
# =============================================================================
# PERFORMANCE OPTIMISATION TIPS
# =============================================================================
#
# For CPU-only systems:
#   MAX_WORKERS=2
#   EMBEDDING_BATCH_SIZE=16
#   LLM_RATE_LIMIT=5.0
#
# For GPU systems (16GB+ VRAM):
#   MAX_WORKERS=8
#   EMBEDDING_BATCH_SIZE=64
#   LLM_RATE_LIMIT=20.0
#
# For large document sets (1000+ docs):
#   PROGRESS_LOG_INTERVAL=50
#   VERSIONS_TO_KEEP=2
#   ENABLE_CHUNK_HEURISTIC_SKIP=true
#
# For maximum quality (slower):
#   ENABLE_CHUNK_HEURISTIC_SKIP=false
#   LLM_RATE_LIMIT=5.0
#   MAX_WORKERS=2
#
# =============================================================================

# =============================================================================
# DOMAIN KEYWORDS PRESERVATION
# =============================================================================

# Comma-separated list of technical terms/brand names to always preserve
# Chunks containing ANY of these terms will be force-preserved and indexed,
# even if they fail quality heuristics. Useful for proper nouns, brand names,
# and domain-specific terminology that LLM may not recognise. Keep list focused.
# 20 - 50 keywords is recommended to avoid excessive preservation. Use exact 
# match, case-sensitive. Substring matches are sufficient (e.g., "OAuth2"
# will match "OAuth2.0" and "OAuth2-based"). Avoid overly generic terms
# Review audit logs for domain_keyword_preserved events.
#
# Examples: Netskope, HIPAA, SOC2, AKS, Kubernetes, OAuth2, etc.
# Default: (empty - no forced preservation)
PRESERVE_DOMAIN_KEYWORDS=NHIPAA,SOC2,PCI-DSS,OAuth2,SAML,JWT,Netskope,ZeroTrust,SIEM,SOAR,GDPR,CCPA,ISO27001,CISSP,CSA,CloudSecurity,DataLossPrevention,DLP,Encryption,MultiFactorAuthentication,MFA,IdentityAccessManagement,IAM

# Path to JSON file with domain keywords (alternative to comma-separated list)
# File format: [\"Netskope\", \"HIPAA\", \"SOC2\", ...]
# Useful for large keyword lists managed separately
# Default: (empty - use PRESERVE_DOMAIN_KEYWORDS env var instead)
DOMAIN_KEYWORDS_FILE=~/rag-project/rag_data/domain_keywords.json

# =============================================================================
# RAG ENHANCEMENT FEATURES (Phase 3)
# =============================================================================

# Enable context caching for frequently accessed entities
# Cache provides 100x faster retrieval for hot entities
# Default: true
RAG_ENABLE_CACHING=true

# Enable graph-enhanced retrieval (relationship-based expansion)
# Expands results with graph-connected chunks from consistency graph
# Default: true
RAG_ENABLE_GRAPH=true

# Enable parent-child chunking (precise search, rich context)
# Search on small child chunks, return large parent chunks to LLM
# Requires re-ingestion to take effect
# Default: true
RAG_ENABLE_PARENT_CHILD=true

# =============================================================================
# LEARNED RERANKER (CROSS-ENCODER)
# =============================================================================

# Enable learned cross-encoder reranking (true/false)
# Default: true
RAG_ENABLE_LEARNED_RERANKING=true

# Hugging Face model identifier for reranker
# Default: BAAI/bge-reranker-base
RAG_RERANKER_MODEL=BAAI/bge-reranker-base

# Device for reranker inference (cpu, cuda, mps)
# Default: cpu
RAG_RERANKER_DEVICE=cpu

# Batch size for reranker inference
# Default: 32
RAG_RERANKER_BATCH_SIZE=32

# Enable on-disk reranker score cache (true/false)
# Default: true
RAG_ENABLE_RERANKER_CACHE=true

# Strict offline mode for reranker model loading (true/false)
# If true, disables Hugging Face network access (HF_HUB_OFFLINE/TRANSFORMERS_OFFLINE)
# and requires the model to already exist in local cache.
# Default: false
RAG_RERANKER_STRICT_OFFLINE=false

# =============================================================================
# HYBRID SEARCH ENHANCEMENTS (Phase 7)
# =============================================================================

# Vector search weight in hybrid results (0.0-1.0)
# Higher = prefer vector search results
# Default: 0.6
RAG_HYBRID_VECTOR_WEIGHT=0.6

# Keyword search weight in hybrid results (0.0-1.0)
# Higher = prefer keyword search results
# Note: Automatically normalised with vector_weight to sum to 1.0
# Default: 0.4
RAG_HYBRID_KEYWORD_WEIGHT=0.4

# Hybrid result combination strategy
# Options: "sum" (weighted sum), "rank_fusion" (RRF), "top_k" (proportional)
# - sum: Linear combination of weighted scores (default)
# - rank_fusion: Reciprocal rank fusion (better for ranking-aware combining)
# - top_k: Take proportional top results from each method
# Default: sum
RAG_HYBRID_COMBINATION_STRATEGY=sum

# Enable query expansion with synonyms and spelling variants
# Expands queries with related terms for better keyword matching
# Default: true
RAG_ENABLE_QUERY_EXPANSION=true

# Enable US/British spelling variant expansion
# Expands queries with spelling alternatives (e.g., optimize/optimise, color/colour)
# Default: true
RAG_ENABLE_SPELLING_VARIANTS=true

# Enable domain-specific synonym expansion
# Expands queries with domain-related terms (e.g., auth -> authentication, access, login)
# Default: true
RAG_ENABLE_DOMAIN_SYNONYMS=true

# Context cache settings
# Maximum number of entities to cache
# Default: 100
RAG_CACHE_MAX_ENTRIES=100

# Cache time-to-live in seconds (0 = no expiration)
# Default: 3600 (1 hour)
RAG_CACHE_TTL_SECONDS=3600

# Graph expansion settings
# Maximum hops for graph neighbor expansion (1 or 2)
# Default: 1
RAG_GRAPH_MAX_HOPS=1

# Maximum neighbors per chunk to include
# Default: 3
RAG_GRAPH_MAX_NEIGHBOURS=3

# =============================================================================
# RESOURCE MONITORING
# =============================================================================

# Enable resource monitoring (CPU, RAM, VRAM, IOPS, network)
# Tracks Python, Ollama, and ChromaDB processes for capacity planning
# Default: false
ENABLE_RESOURCE_MONITORING=false

# Resource monitoring sampling interval in seconds
# Default: 1.0
RESOURCE_MONITORING_INTERVAL=1.0

# Monitor Ollama process resource usage
# Default: true
MONITOR_OLLAMA=true

# Monitor ChromaDB process resource usage
# Default: true
MONITOR_CHROMADB=true

# =============================================================================
# DOMAIN KEYWORDS
# =============================================================================

#
# Examples: Netskope, HIPAA, SOC2, AKS, Kubernetes, OAuth2, etc.
# Default: (empty - no forced preservation)
PRESERVE_DOMAIN_KEYWORDS=NHIPAA,SOC2,PCI-DSS,OAuth2,SAML,JWT,Netskope,ZeroTrust,SIEM,SOAR,GDPR,CCPA,ISO27001,CISSP,CSA,CloudSecurity,DataLossPrevention,DLP,Encryption,MultiFactorAuthentication,MFA,IdentityAccessManagement,IAM

# Path to JSON file with domain keywords (alternative to comma-separated list)
# File format: ["Netskope", "HIPAA", "SOC2", ...]
# Useful for large keyword lists managed separately
# Default: (empty - use PRESERVE_DOMAIN_KEYWORDS env var instead)
DOMAIN_KEYWORDS_FILE=~/rag-project/rag_data/domain_keywords.json

